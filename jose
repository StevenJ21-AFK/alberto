#include <iostream>

using namespace std;

int main() {
    int numero;
    
    cout << "Ingresa un numero entero: ";
    cin >> numero;
    
    if (numero % 2 == 0) {
        cout << "El numero " << numero << " es PAR." << endl;
    } else {
        cout << "El numero " << numero << " es IMPAR." << endl;
    }
    
    return 0;
}

